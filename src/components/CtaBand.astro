---
import { withBase } from '../utils/url';
import type { ThemeName } from '../data/site';
import { getThemeStyle } from '../utils/theme';

interface Props {
  title: string;
  body: string;
  cta: {
    label: string;
    href: string;
  };
  theme?: ThemeName;
}

const { title, body, cta, theme } = Astro.props;
const themeStyle = getThemeStyle(theme);
---

<section class="cta-band" style={themeStyle}>
  <div class="site-shell cta-inner">
    <div>
      <h2>{title}</h2>
      <p>{body}</p>
    </div>
    <a class="button button-primary" href={withBase(cta.href)}>{cta.label}</a>
  </div>
</section>
