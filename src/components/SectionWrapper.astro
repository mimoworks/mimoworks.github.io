---
import type { ThemeName } from '../data/site';
import { getThemeStyle } from '../utils/theme';

interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
  theme?: ThemeName;
  class?: string;
}

const { eyebrow, title, body, theme, class: className = '' } = Astro.props;
const themeStyle = getThemeStyle(theme);
---

<section class:list={['section', className]} style={themeStyle}>
  <div class="site-shell">
    {
      (eyebrow || title || body) && (
        <div class="section-heading">
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          {title && <h2>{title}</h2>}
          {body && <p>{body}</p>}
        </div>
      )
    }
    <slot />
  </div>
</section>
