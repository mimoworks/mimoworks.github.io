---
import SiteLayout from '../layouts/SiteLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import Card from '../components/Card.astro';
import CtaBand from '../components/CtaBand.astro';
import ProductVisual from '../components/ProductVisual.astro';
import { connectContent, connectMode, visualAssets } from '../data/site';

const useCases =
  connectMode === 'teaser'
    ? connectContent.useCases.items.slice(0, 2)
    : connectContent.useCases.items;
---

<SiteLayout
  title="mimo connect"
  description="Practical tap and scan objects for counters, reception desks, and everyday business spaces."
  path="/connect/"
  theme="connect"
>
  <HeroSection
    {...connectContent.hero}
    theme="connect"
    backgroundImage="/images/hero/mimoconnect-hero.png"
    backgroundPosition="84% center"
    backgroundPositionTablet="62% center"
    backgroundPositionMobile="56% center"
  />

  <SectionWrapper {...connectContent.overview} theme="connect">
    <div class="feature-layout">
      <ProductVisual variant="connect" image={visualAssets.connectHero} compact />
      <Card
        title={connectContent.status.title}
        body={connectContent.status.body}
        theme="connect"
      />
    </div>
  </SectionWrapper>

  <SectionWrapper
    title={connectContent.benefits.title}
    theme="connect"
    class="benefits-row"
  >
    <div class="card-grid compact-cards">
      {
        connectContent.benefits.items.map((item) => (
          <Card title={item.title} body={item.body} theme="connect" />
        ))
      }
    </div>
  </SectionWrapper>

  <SectionWrapper
    title={connectContent.useCases.title}
    theme="connect"
    class="use-case-grid"
  >
    <div class="card-grid">
      {
        useCases.map((item) => (
          <Card eyebrow="Use case" title={item.title} body={item.body} theme="connect" />
        ))
      }
    </div>
  </SectionWrapper>

  <CtaBand {...connectContent.contact} theme="connect" />
</SiteLayout>
