{
  "site": {
    "brand": "mimoworks",
    "tagline": "Thoughtful objects and tools.",
    "tone": ["thoughtful", "practical", "modern", "quiet"]
  },
  "typography": {
    "primary": "Inter, ui-sans-serif, system-ui, sans-serif",
    "scale": {
      "hero": "clamp(2.5rem, 5vw, 5rem)",
      "h1": "clamp(2rem, 4vw, 3.5rem)",
      "h2": "clamp(1.5rem, 3vw, 2.25rem)",
      "body": "1rem",
      "small": "0.875rem"
    },
    "tracking": {
      "tight": "-0.03em",
      "normal": "0",
      "wide": "0.08em"
    }
  },
  "radius": {
    "sm": "0.5rem",
    "md": "0.875rem",
    "lg": "1.25rem",
    "xl": "1.75rem"
  },
  "spacing": {
    "container": "min(1120px, calc(100vw - 2rem))",
    "sectionY": "clamp(4rem, 8vw, 8rem)",
    "cardGap": "1.25rem"
  },
  "themes": {
    "core": {
      "bg": "#F7F4EE",
      "surface": "#FFFDF9",
      "text": "#1F1B17",
      "muted": "#6F665D",
      "border": "#DED7CE",
      "accent": "#8B7762",
      "hero-fade-target": "#171310"
    },
    "lumofield": {
      "bg": "#F7F2EA",
      "surface": "#FFFDF8",
      "text": "#241D17",
      "muted": "#75685A",
      "border": "#E4D7C8",
      "accent": "#B78B56",
      "accentSoft": "#E9D4B6",
      "hero-fade-target": "#17120e"
    },
    "connect": {
      "bg": "#F4F5F6",
      "surface": "#FFFFFF",
      "text": "#15181B",
      "muted": "#66707A",
      "border": "#D6DCE2",
      "accent": "#4E6A84",
      "accentSoft": "#DCE8F1",
      "hero-fade-target": "#1a2027"
    }
  },
  "buttons": {
    "primary": {
      "bg": "var(--accent)",
      "text": "#FFFFFF",
      "radius": "9999px"
    },
    "secondary": {
      "bg": "transparent",
      "text": "var(--text)",
      "border": "1px solid var(--border)",
      "radius": "9999px"
    }
  }
}
