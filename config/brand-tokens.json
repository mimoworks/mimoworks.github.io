{
  "site": {
    "brand": "mimoworks",
    "tagline": "Thoughtful objects and tools.",
    "tone": ["thoughtful", "practical", "modern", "quiet"],
    "connectMode": {
      "default": "teaser",
      "options": ["hidden", "teaser", "public"]
    }
  },
  "typography": {
    "primary": "Inter, ui-sans-serif, system-ui, sans-serif",
    "fonts": {
      "ui": {
        "family": "Inter",
        "path": "/fonts/inter/inter.woff2"
      },
      "display": {
        "family": "Fraunces",
        "path": "/fonts/fraunces/fraunces.woff2"
      },
      "tokens": {
        "ui": "--font-ui",
        "display": "--font-display"
      }
    },
    "scale": {
      "hero": "clamp(2.5rem, 5vw, 5rem)",
      "h1": "clamp(2rem, 4vw, 3.5rem)",
      "h2": "clamp(1.5rem, 3vw, 2.25rem)",
      "body": "1rem",
      "small": "0.875rem"
    },
    "tracking": {
      "tight": "-0.03em",
      "normal": "0",
      "wide": "0.08em"
    }
  },
  "radius": {
    "sm": "0.5rem",
    "md": "0.875rem",
    "lg": "1.25rem",
    "xl": "1.75rem"
  },
  "spacing": {
    "container": "min(1120px, calc(100vw - 2rem))",
    "sectionY": "clamp(4rem, 8vw, 8rem)",
    "cardGap": "1.25rem"
  },
  "themes": {
    "core": {
      "bg": "#F7F4EE",
      "surface": "#FFFDF9",
      "text": "#1F1B17",
      "muted": "#6F665D",
      "border": "#DED7CE",
      "accent": "#8B7762",
      "hero-fade-target": "#171310"
    },
    "lumofield": {
      "bg": "#F7F2EA",
      "surface": "#FFFDF8",
      "text": "#241D17",
      "muted": "#75685A",
      "border": "#E4D7C8",
      "accent": "#B78B56",
      "accentSoft": "#E9D4B6",
      "hero-fade-target": "#17120e"
    },
    "connect": {
      "bg": "#F4F5F6",
      "surface": "#FFFFFF",
      "text": "#15181B",
      "muted": "#66707A",
      "border": "#D6DCE2",
      "accent": "#4E6A84",
      "accentSoft": "#DCE8F1",
      "hero-fade-target": "#1a2027"
    }
  },
  "themeIntents": {
    "core": {
      "role": "umbrella-editorial",
      "headerMode": "overlay",
      "typographyEmphasis": "balanced-serif-led",
      "ctaTone": ["explore", "discover", "understand-the-studio"],
      "sectionDensity": "editorial-balanced",
      "imageryDirection": [
        "editorial still life",
        "sculptural objects",
        "broader studio mood"
      ],
      "palette": {
        "bg-main": "#f3eee7",
        "bg-surface": "#fbf8f3",
        "bg-elevated": "#e9e0d4",
        "bg-hero-dark": "#17120f",
        "text-primary": "#171411",
        "text-secondary": "#5f564d",
        "text-muted": "#8a8075",
        "accent-main": "#b68b5f",
        "accent-soft": "#e4d4bb",
        "border-subtle": "rgba(23,20,17,0.10)",
        "hero-fade-target": "#17120f"
      },
      "sections": ["BrandExpressionsSection", "StudioPrinciplesBand"]
    },
    "lumofield": {
      "role": "warm-product-line",
      "headerMode": "overlay",
      "typographyEmphasis": "strongest-serif",
      "ctaTone": ["enquire", "view-collection", "express-interest"],
      "sectionDensity": "immersive-product",
      "imageryDirection": [
        "lamp-led composition",
        "bedside shelf desk placements",
        "warm evening domestic glow"
      ],
      "palette": {
        "bg-main": "#0f0c0a",
        "bg-surface": "#17110e",
        "bg-elevated": "#221a16",
        "text-primary": "#f2ede7",
        "text-secondary": "#cabfae",
        "text-muted": "#9d9287",
        "accent-main": "#c89a5b",
        "accent-soft": "#e8d8bd",
        "border-subtle": "rgba(255,255,255,0.08)",
        "hero-fade-target": "#0f0c0a"
      },
      "sections": ["CollectionStudiesGrid", "PlacementStorySection"]
    },
    "connect": {
      "role": "practical-business-tools",
      "headerMode": "solid",
      "typographyEmphasis": "sans-led",
      "ctaTone": ["request-info", "for-businesses", "pilot-contact"],
      "sectionDensity": "clear-structured",
      "imageryDirection": [
        "counter reception and hospitality contexts",
        "product-in-use and product-on-surface",
        "light and clean environment"
      ],
      "palette": {
        "bg-main": "#f7f4f1",
        "bg-surface": "#ffffff",
        "bg-elevated": "#efebe6",
        "text-primary": "#171717",
        "text-secondary": "#57524b",
        "text-muted": "#8a837a",
        "accent-main": "#1d1d1f",
        "accent-soft": "#d9d2cb",
        "border-subtle": "rgba(0,0,0,0.08)",
        "hero-fade-target": "#f7f4f1"
      },
      "sections": ["BenefitsRow", "UseCaseGrid"]
    }
  },
  "launch": {
    "connectMode": {
      "default": "teaser",
      "options": ["hidden", "teaser", "public"],
      "teaserMeaning": [
        "connect remains secondary in main public flow",
        "homepage can hint that something is brewing",
        "system stays ready to promote connect to public later"
      ]
    }
  },
  "buttons": {
    "primary": {
      "bg": "var(--accent)",
      "text": "#FFFFFF",
      "radius": "9999px"
    },
    "secondary": {
      "bg": "transparent",
      "text": "var(--text)",
      "border": "1px solid var(--border)",
      "radius": "9999px"
    }
  }
}
